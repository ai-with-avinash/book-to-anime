# BookToAnime — local-run secrets and overrides. Copy to `.env` and edit.
# `.env` is gitignored. Never commit a real token.

# ============================== LIP-SYNC ====================================
# Replicate-hosted SadTalker for talking-anime mouth animation.
# Get one at https://replicate.com/account/api-tokens
# Without this, lipsync_enabled=true on a job will fail; lipsync=false works.
REPLICATE_API_TOKEN=

# ============================== LANGUAGE (LLM) ===============================
# Any OpenAI-compatible /v1/chat/completions endpoint.
# Defaults below are for local Ollama.
BOOKTOANIME_LLM_BASE_URL=http://localhost:11434/v1
BOOKTOANIME_LLM_MODEL=llama3.2:3b
BOOKTOANIME_LLM_API_KEY=ollama
BOOKTOANIME_LLM_TIMEOUT_S=300

# Hosted alternatives — uncomment one block:
# BOOKTOANIME_LLM_BASE_URL=https://api.openai.com/v1
# BOOKTOANIME_LLM_MODEL=gpt-4o-mini
# BOOKTOANIME_LLM_API_KEY=sk-...

# BOOKTOANIME_LLM_BASE_URL=https://api.groq.com/openai/v1
# BOOKTOANIME_LLM_MODEL=llama-3.3-70b-versatile
# BOOKTOANIME_LLM_API_KEY=gsk_...

# ============================== TTS (Kokoro) =================================
BOOKTOANIME_TTS_VOICE_ID=af_bella
BOOKTOANIME_TTS_LANGUAGE=en-US
BOOKTOANIME_TTS_SAMPLE_RATE=24000

# ============================== VISUAL (SDXL) ================================
# Skip portrait generation entirely (and the 7 GB SDXL download) by pointing
# this at any anime PNG. PersonaOnlyVisual then copies it to every shot.
# BOOKTOANIME_PERSONA_PATH=/absolute/path/to/anime_face.png

BOOKTOANIME_SDXL_CHECKPOINT=stabilityai/stable-diffusion-xl-base-1.0
BOOKTOANIME_SDXL_IP_ADAPTER_REPO=h94/IP-Adapter
BOOKTOANIME_SDXL_IP_ADAPTER_SUBFOLDER=sdxl_models
BOOKTOANIME_SDXL_IP_ADAPTER_WEIGHTS=ip-adapter-plus_sdxl_vit-h.safetensors
BOOKTOANIME_SDXL_WIDTH=1024
BOOKTOANIME_SDXL_HEIGHT=1024
BOOKTOANIME_SDXL_STEPS=20
BOOKTOANIME_SDXL_GUIDANCE=5.5
